---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const reportData = `
if (typeof window !== "undefined") {
  const hash = window.location.hash.slice(1);
  if (hash) {
    try {
      const data = JSON.parse(decodeURIComponent(atob(hash)));
      window.__clm_report__ = data;
    } catch (e) {
      console.error("Failed to parse CLM report data");
    }
  }
}
`;
---

<BaseLayout title="CLM Incident Report" description="A Career Limiting Maneuver has been detected.">
  <div class="card" id="report-card">
    <div class="card-header">
      <span class="icon">📋</span>
      <h2 class="card-title">CLM Incident Report</h2>
    </div>
    <div id="report-content" class="report-content" style="min-height: 80px; color: var(--muted);">
      Loading report...
    </div>
    <div id="report-wallet" style="display: none;"></div>
    <div style="margin-top: 16px; text-align: center;">
      <a href="/" style="color: var(--link);">← Back to home</a>
    </div>
  </div>
</BaseLayout>

<script set:html={reportData} is:inline></script>

<script>
  function init() {
    const data = (window as any).__clm_report__;
    if (!data) {
      document.getElementById("report-content")!.innerHTML =
        '<span class="error">No valid report found. Generate one from the home page.</span>';
      return;
    }

    document.getElementById("report-content")!.textContent = data.report;

    if (data.wallet) {
      const walletEl = document.getElementById("report-wallet");
      walletEl!.removeAttribute("style");
      walletEl!.innerHTML = `
        <div class="wallet-card">
          <div class="header">
            <span class="brand-text">Career Limiting Maneuver</span>
            <span class="logo">⚠️</span>
          </div>
          <div class="reason">${escapeHtml(data.wallet.reason)}</div>
          <div class="details">${escapeHtml(data.wallet.date)}</div>
          <div class="id-number">CLM-${escapeHtml(data.wallet.id)}</div>
        </div>
      `;
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
