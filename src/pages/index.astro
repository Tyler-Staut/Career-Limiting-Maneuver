import BaseLayout from '../layouts/BaseLayout.astro';
import BentoGrid from '../components/BentoGrid.astro';
import CardHero from '../components/CardHero.astro';
import CardGlobe from '../components/CardGlobe.astro';
import CardIncidentGen from '../components/CardIncidentGen.astro';
import CardRecentReports from '../components/CardRecentReports.astro';

const accept = Astro.request.headers.get('accept') || '';
const userAgent = (Astro.request.headers.get('user-agent') || '').toLowerCase();
const url = new URL(Astro.request.url);
const cmd = url.searchParams.get('cmd');

const responses: Record<string, string> = {
  help: `Available commands:
  help        Show this help message
  status      Check your career status
  whoami      Identify yourself
  report      Generate a CLM report
  ls          List your mistakes
  rm -rf /    Nice try.
  sudo make me a sandwich
  fortune     Get a CLM fortune
  clear       Clear the terminal`,
  
  fortune: getRandomFortune(),
  
  status: `‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ  80%
Career Status: TERMINALLY COMPROMISED
Outlook: Bleak but entertaining
Manager Awareness Level: HIGH
HR Tickets Open: 3

Your career is in critical condition. Please enjoy responsibly.`,
  
  whoami: `clm-enthusiast (uid=666)
groups: bad-decisions, career-suicide, fun-having
shell: /bin/regret
home: /dev/null

You are a certified Career Limiting Maneuver practitioner.`,
  
  report: `Incident Report #${Math.floor(Math.random() * 9999)}
Date: ${new Date().toISOString().split("T")[0]}
Severity: MAXIMUM
Action: You pulled a CLM
Status: Irreversible

Note: This report has been filed with HR.
(They're still laughing.)`,
  
  "ls": `Drwxr-xr-x  bad-decisions/
Drwxr-xr-x  career-sabotage/
-rw-r--r--  regrets.txt (4.2MB)
-rw-r--r--  excuses.md (empty)
lrwxrwxrwx  promotion -> /dev/null
-rwxr-xr-x  clm.sh (executable)

Total: ${Math.floor(Math.random() * 99)} career-limiting maneuvers found.`,
  
  "rm -rf /": `Nice try. We've seen this before.
Your attempt has been logged as Incident #${Math.floor(Math.random() * 9999)}.
HR has been notified. Again.`,
  
  "sudo make me a sandwich": `User clm-enthusiast is not in the sudoers file.
This incident will be reported.
(Just like everything else you do.)

...but here's a virtual sandwich anyway: ūü•™`,
};

function getRandomFortune(): string {
  const fortunes = [
    "A career limiting maneuver is in your immediate future. You're living it right now.",
    "Your code will be reviewed by someone who doesn't understand it. This is fine.",
    "You will accidentally reply-all to the company. The subject line will be questionable.",
    "A deployment on Friday will teach you the true meaning of regret.",
    "Your git push --force will be the one time you shouldn't have used it.",
    "The person who reviews your PR will be the CEO.",
    "You will name a variable something you'll regret in 3 years.",
    "A meeting that could have been an email will consume your entire afternoon.",
  ];
  return fortunes[Math.floor(Math.random() * fortunes.length)];
}

if (cmd) {
  const response = responses[cmd.toLowerCase()] || `Command not found: ${cmd}\nType 'help' for available commands.`;
  return new Response(response, {
    headers: { 'content-type': 'text/plain; charset=utf-8' },
  });
}

