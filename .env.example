# Cloudflare Turnstile (get from https://dash.cloudflare.com/?to=/:account/turnstile)
# Use 1x00000000000000000000AA for testing (always passes)
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Cloudflare AI Gateway (get from https://dash.cloudflare.com/?to=/:account/ai/ai-gateway)
# Format: https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/GATEWAY_NAME/compat/chat/completions
AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/clm-gateway/compat/chat/completions
AI_GATEWAY_TOKEN=your_cloudflare_api_token_here

